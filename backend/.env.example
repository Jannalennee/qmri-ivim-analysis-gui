# Required to run real inference via external command
QMRI_TEMPLATE_YAML=/home/rnga/jlenne/path/to/template_inference.yaml
QMRI_CHECKPOINT_PATH=/home/rnga/jlenne/path/to/model.ckpt
QMRI_RUN_COMMAND=python run.py
QMRI_RUN_WORKING_DIR=/home/rnga/jlenne/dce_rim/Janna/inference

# Optional
QMRI_ALLOWED_ORIGINS=http://localhost:4200
QMRI_OUTPUT_JSON_PATH=results/latest/maps.json
QMRI_OUTPUT_H5_PATH=results/latest/maps.h5
QMRI_OUTPUT_H5_DATASETS=T1:T1:ms;T2:T2:ms;PD:PD:fraction;Uncertainty:Uncertainty:score
QMRI_RUN_TIMEOUT_SECONDS=900
